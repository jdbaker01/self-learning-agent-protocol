# Copy to .env.local and fill in.
OPENAI_API_KEY=sk-...

# Optional overrides — defaults in src/rspl/infra/modelManager.ts.
# SLAP_CHAT_MODEL=gpt-4.1-mini
# SLAP_REFLECT_MODEL=gpt-4.1
# SLAP_SELECT_MODEL=gpt-4.1
# SLAP_JUDGE_MODEL=gpt-4.1-mini
# SLAP_EMBED_MODEL=text-embedding-3-small

# Optional data directory override (defaults to ./data)
# SLAP_DATA_DIR=./data
